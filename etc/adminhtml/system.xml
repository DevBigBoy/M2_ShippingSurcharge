<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="market" translate="label" sortOrder="900">
            <label>Market</label>
        </tab>

        <section id="shipping_surcharge" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Shipping Surcharge</label>
            <tab>market</tab>
            <resource>Market_ShippingSurcharge::config</resource>
            <group id="general" translate="label" sortOrder="900" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Configuration</label>
                <field id="enabled" translate="label" type="select" sortOrder="900" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Shipping Surcharge</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
        <section id="sales">
            <group id="totals_sort">
                <field id="surcharge" translate="label" type="text" sortOrder="3" showInDefault="1" showInWebsite="1" showInStore="0" canRestore="1">
                    <label>Shipping Surcharge</label>
                </field>
            </group>
        </section>
    </system>
</config>
